[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/combat_ui.gd" id="1_script"]

[node name="CombatScene" type="Control" node_paths=PackedStringArray("log_text_edit", "btn_close", "result_label")]
layout_mode = 3
